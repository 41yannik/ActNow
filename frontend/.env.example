# See ../.env.example for the full set of Supabase variables.
# Only VITE_* vars are exposed to the browser.
#
# Local stack:  http://127.0.0.1:54321 + the sb_publishable_... key from `supabase status`
# Staging:      https://<project-ref>.supabase.co + the publishable key from the dashboard
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_replace-me
