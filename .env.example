# Supabase URL (public). Local stack: http://127.0.0.1:54321 — Staging: https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Publishable key (safe for browser usage; subject to RLS).
# Format sb_publishable_... — from `supabase status` (local) or the dashboard (cloud).
SUPABASE_ANON_KEY=sb_publishable_replace-me

# Service role key / secret key — NEVER expose to the browser or commit. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-your-service-role-key

# Direct Postgres connection string (used for psql, e.g. supabase/tests/rls_smoke.sql)
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Frontend (Vite) — same values, exposed via VITE_ prefix
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_replace-me
