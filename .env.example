# Supabase URL (public)
SUPABASE_URL=http://localhost:54321

# Public anon key (safe for browser usage; subject to RLS)
SUPABASE_ANON_KEY=replace-me-with-your-anon-key

# Service role key — NEVER expose to the browser or commit. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-your-service-role-key

# Direct Postgres connection string (used to apply docs/schema.sql + docs/seed.sql)
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Frontend (Vite) — same anon key, exposed via VITE_ prefix
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=replace-me-with-your-anon-key
